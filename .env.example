# Local Supabase project overrides (optional — fall back to the values in
# utils/supabase/info.tsx when not set)
# VITE_SUPABASE_PROJECT_ID=
# VITE_SUPABASE_ANON_KEY=

# When set to "true", the app auto-creates an in-memory "default-admin"
# session on first load so you can click around without signing in. This is
# intended for local dev/demo only — leave it unset in pilot and production
# builds so users land on /login.
# VITE_ENABLE_DEFAULT_ADMIN=true

# -----------------------------------------------------------------------------
# Google sign-in
# -----------------------------------------------------------------------------
# The "Continue with Google" button on /login uses Supabase Auth's OAuth flow,
# so no client-side secrets are required here. Configuration lives in Supabase:
#
#   1. Supabase dashboard → Authentication → Providers → Google → enable.
#   2. Paste the Google OAuth Client ID and Client Secret from Google Cloud
#      Console (OAuth 2.0 Client of type "Web application").
#   3. Authentication → URL Configuration → add every app origin to
#      "Site URL" / "Redirect URLs":
#        - http://localhost:5173/login   (vite dev)
#        - https://<your-netlify-domain>/login
#        - any preview/staging domains
#   4. In Google Cloud Console, register the Supabase callback as an authorized
#      redirect URI for the OAuth client:
#        https://<project-ref>.supabase.co/auth/v1/callback
#
# Role handling: Google users start with role 'sqm' (least privilege). Promote
# admins by setting user_metadata.role = 'admin' (or app_metadata.role) on the
# user in Supabase Auth.

# -----------------------------------------------------------------------------
# Send Incident Report to Customer (Netlify function)
# -----------------------------------------------------------------------------
# The "Send to Customer" action on a Closed incident posts the final PDF to
# /api/send-incident-report (netlify/functions/send-incident-report.js), which
# delivers via one of the supported providers below and writes an audit trail
# back to the incidents row.
#
# Set these in Netlify → Site settings → Build & deploy → Environment.
# Locally, you can put them in .env (not committed) and use `netlify dev`.
#
# MAIL_PROVIDER         resend | sendgrid | log   (default: log — no email is
#                       actually sent; useful for dev)
# MAIL_FROM             from-address, e.g. "XConnect Field Service <reports@xconnect.example>"
# MAIL_REPLY_TO         optional reply-to email
#
# Provider-specific secrets (only set the one matching MAIL_PROVIDER):
#   RESEND_API_KEY      Resend API key
#   SENDGRID_API_KEY    SendGrid API key
#
# Audit trail (incidents.report_sent / report_sent_to / report_sent_by) uses
# the Supabase service-role key from the Netlify function — set BOTH:
#   SUPABASE_URL                  https://<project>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY     service-role JWT (NEVER expose to clients)
#
# Schema: apply database-migrations/incident_report_send_audit.sql once to add
# the audit columns. If you skip it the audit write fails gracefully and the
# client falls back to writing report_sent only.
